        "id": "FLQjsCqGubgC"
      },
      "source": [
        "### 2.2 Probabilitas Kondisional P(F_i | K)\n",
        "\n",
        "Untuk setiap fitur dalam kasus uji, hitung berapa kali nilainya muncul dalam tiap kelas, dibagi total baris kelas tersebut."
      ],
      "id": "FLQjsCqGubgC"
    },
    {
      "cell_type": "code",
      "execution_count": 22,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "oQAfm2-JubgD",
        "outputId": "52791b89-f805-4aaf-8d1b-ffada00c074c"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Kelas Yes: 0.2222222222222222 0.3333333333333333 0.3333333333333333 0.3333333333333333\n",
            "Kelas No : 0.6 0.2 0.8 0.6\n"
          ]
        }
      ],
      "source": [
        "df_yes = df[df[\"Play\"] == \"Yes\"]\n",
        "df_no = df[df[\"Play\"] == \"No\"]\n",
        "\n",
        "# TODO 3: Hitung 4 probabilitas kondisional untuk kelas Yes\n",
        "# Contoh: p_sunny_yes = (df_yes['Outlook'] == 'Sunny').sum() / len(df_yes)\n",
        "p_sunny_yes  = (df_yes['Outlook'] == 'Sunny').sum() / len(df_yes)\n",
        "p_cool_yes   = (df_yes['Temperature'] == 'Cool').sum() / len(df_yes)\n",
        "p_high_yes   = (df_yes['Humidity'] == 'High').sum() / len(df_yes)\n",
        "p_strong_yes = (df_yes['Wind'] == 'Strong').sum() / len(df_yes)\n",
        "\n",
        "# TODO 4: Hitung 4 probabilitas kondisional untuk kelas No\n",
        "p_sunny_no  = (df_no['Outlook'] == 'Sunny').sum() / len(df_no)\n",
        "p_cool_no   = (df_no['Temperature'] == 'Cool').sum() / len(df_no)\n",
        "p_high_no   = (df_no['Humidity'] == 'High').sum() / len(df_no)\n",
        "p_strong_no = (df_no['Wind'] == 'Strong').sum() / len(df_no)\n",
        "\n",
        "print(\"Kelas Yes:\", p_sunny_yes, p_cool_yes, p_high_yes, p_strong_yes)\n",
        "print(\"Kelas No :\", p_sunny_no,  p_cool_no,  p_high_no,  p_strong_no)"
      ],
      "id": "oQAfm2-JubgD"
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "CD72AUWOubgD"
      },
      "source": [
        "### 2.3 Posterior & Keputusan"
      ],
      "id": "CD72AUWOubgD"
    },
    {
      "cell_type": "code",
      "execution_count": 23,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "y6LD_1SrubgD",
        "outputId": "2a4fb0be-4fc3-4272-ee57-d6ccadbaff07"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "P(Yes | x) = 0.2046\n",
            "P(No  | x) = 0.7954\n",
            "Prediksi manual: No\n"
          ]
        }
      ],
      "source": [
        "# TODO 5: Hitung skor posterior (proporsional, belum dinormalisasi)\n",
        "score_yes = p_yes * p_sunny_yes * p_cool_yes * p_high_yes * p_strong_yes\n",
        "score_no  = p_no  * p_sunny_no  * p_cool_no  * p_high_no  * p_strong_no\n",
        "\n",
        "# TODO 6: Normalisasi sehingga total = 1\n",
        "total = score_yes + score_no\n",
        "post_yes = score_yes / total\n",
        "post_no  = score_no / total\n",
        "\n",
        "prediksi_manual = \"Yes\" if post_yes > post_no else \"No\"\n",
        "\n",
        "print(f\"P(Yes | x) = {post_yes:.4f}\")\n",
        "print(f\"P(No  | x) = {post_no:.4f}\")\n",
        "print(f\"Prediksi manual: {prediksi_manual}\")"
      ],
      "id": "y6LD_1SrubgD"
    },
