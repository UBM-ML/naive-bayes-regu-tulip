      ],
      "source": [
        "# TODO 2: Hitung P(Yes) dan P(No)\n",
        "n_total = len(df)   # total baris\n",
        "n_yes = (df['Play'] == 'Yes').sum()     # jumlah Play == 'Yes'\n",
        "n_no = (df['Play'] == 'No').sum()      # jumlah Play == 'No'\n",
        "\n",
        "p_yes = n_yes / n_total\n",
        "p_no = n_no / n_total\n",
        "\n",
        "print(f\"P(Yes) = {p_yes:.4f}\")\n",
        "print(f\"P(No)  = {p_no:.4f}\")"
